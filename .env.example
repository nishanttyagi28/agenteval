# Copy this file to .env and fill in real values (.env itself is gitignored,
# never committed). Nothing here is required for local, non-hosted use --
# agenteval works fully without any of these until you opt into the specific
# feature that needs one. See README's "Deployment (Coming Soon)" section:
# none of this activates real hosting by itself.

# core.judge / agenteval calibrate: Groq API key used by the Agentic Data
# Analyst sibling repo's LLM client (agents/llm_client.py there).
GROQ_API_KEY=

# core.alerts (Tier 5): webhook URL for Slack/Discord regression alerts.
# The *name* you put here is arbitrary -- it's whatever name you reference
# in agents.yaml's `alerting.webhook_url_env`, not a fixed variable name.
AGENTEVAL_SLACK_WEBHOOK_URL=

# core.config.resolve_agent_repo: override for locating the sibling agent
# repository (Agentic Data Analyst) when it isn't a clean sibling clone.
AGENTIC_ANALYST_PATH=

# core.rbac (Tier 7): path to an optional rbac.yaml. RBAC has no active
# enforcement today -- this is only read by code that explicitly loads it.
AGENTEVAL_RBAC_CONFIG=rbac.yaml
